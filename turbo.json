{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "format": {},
    "lint": {},
    "test": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "@rassa/ai-service#build": {
      "outputs": []
    }
  }
}
